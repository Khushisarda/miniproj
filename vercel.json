{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "^/$",
      "dest": "web/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ]
}