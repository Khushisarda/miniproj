{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "web/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "web/app.js",
      "use": "@vercel/static"
    },
    {
      "src": "web/login.html",
      "use": "@vercel/static"
    },
    {
      "src": "web/firebase-config.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/?(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/index.py?source=cron",
      "schedule": "0 18 * * *"
    }
  ]
}